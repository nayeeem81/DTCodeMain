@using Common;
@using FineArtsWebApp;
@model ProductFileViewModel;
@using Microsoft.AspNetCore.Mvc.Localization;
@using Microsoft.Extensions.Localization;
@inject IStringLocalizer<SharedResource> SharedLocalizer

<div class="image-content">
    <div title="Product Image">
        <a class="thumbnail">
            @if (Model != null && Model.ImageFileContent != null && Model.ImageFileContent.Length > 1)
            {
                string imageBase64 = Convert.ToBase64String(Model.ImageFileContent);
                string imageSrc = string.Format("data:image/gif;base64,{0}", imageBase64);
                <img src="@imageSrc"
                     class="img-responsive new-post-mobile-image"
                     alt="Product image"
                     style="max-height:140px; max-width:100%;width:100%;" />
            }
            else
            {
                <img src="~/lib/Images/Home/camera.png"
                     class="img-responsive new-post-mobile-image"
                     alt="Product image is not avaliable"
                     style="max-height:140px; max-width:100%;width:100%;" />
                <span id="infoErrorUpload1" style="display:none;color:red;font-size:smaller;">
                    File size must be less than 7MB!
                </span>
            }
        </a>
    </div>
    <button type="button" class="light-button btn-remove-image" data-id="@Model.ProductImageFileID" data-postId="@Model.ProductID">
        REMOVE
    </button>    
</div>





